@model IEnumerable<Uniwear.ViewModels.CartViewModel>

<a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark mb-3">
    ← Back to Products
</a>

<div class="container mt-4">

    <h2 class="shopping-title">SHOPPING BAG</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Your cart is empty.
        </div>
    }
    else
    {
        <div class="row">

            <!-- LEFT SIDE -->
            <div class="col-lg-8">

                @foreach (var item in Model)
                {
                    <div class="card mb-3 shadow-sm">
                        <div class="row g-0 align-items-center">

                            <!-- Product Image -->
                            <div class="col-md-3 text-center p-2">
                                <img src="@item.ImageUrl"
                                     class="img-fluid rounded"
                                     style="max-height:120px;" />
                            </div>

                            <!-- Product Info -->
                            <div class="col-md-6">
                                <div class="card-body">

                                    <h5 class="card-title">@item.ProductName</h5>

                                    <p class="text-muted mb-1">
                                        Price: ₹ @item.Price
                                    </p>

                                    <p class="mb-2">
                                        Stock:

                                        @if (item.StockQuantity > 5)
                                        {
                                            <span class="text-success fw-bold">
                                                In Stock (@item.StockQuantity)
                                            </span>
                                        }
                                        else if (item.StockQuantity > 0)
                                        {
                                            <span class="text-warning fw-bold">
                                                Only @item.StockQuantity left
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">
                                                Out of Stock
                                            </span>
                                        }
                                    </p>

                                    <!-- Quantity Buttons -->
                                    <div class="d-flex align-items-center gap-2">

                                        <!-- Minus -->
                                        <a asp-controller="Cart"
                                           asp-action="Decrease"
                                           asp-route-cartItemId="@item.CartItemId"
                                           class="btn btn-outline-secondary btn-sm">
                                            -
                                        </a>

                                        <strong>@item.Quantity</strong>

                                        @if (item.Quantity < item.StockQuantity)
                                        {
                                            <a asp-controller="Cart"
                                               asp-action="Increase"
                                               asp-route-cartItemId="@item.CartItemId"
                                               class="btn btn-outline-secondary btn-sm">
                                                +
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm" disabled>
                                                +
                                            </button>
                                        }
                                    </div>

                                    <!-- Total -->
                                    <p class="fw-bold text-success mt-2">
                                        Total: ₹ @item.TotalPrice
                                    </p>

                                </div>
                            </div>

                            <!-- Remove -->
                            <div class="col-md-3 text-center">

                                <a asp-action="Remove"
                                   asp-route-cartItemId="@item.CartItemId"
                                   class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Remove
                                </a>

                            </div>

                        </div>
                    </div>
                }

            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-4">

                <div class="card shadow-sm p-3">

                    <h4 class="fw-bold">Order Summary</h4>

                    <hr />

                    <h5>
                        Total:
                        <span class="text-success">
                            ₹ @Model.Sum(x => x.TotalPrice)
                        </span>
                    </h5>

                    <form asp-controller="Payment"
                          asp-action="CreateCheckoutSession"
                          method="post">

                        <input type="hidden"
                               name="amount"
                               value="@Model.Sum(x => x.TotalPrice)" />

                        <button type="submit"
                                class="btn btn-success w-100 mt-3">
                            Pay with Stripe
                        </button>

                    </form>

                </div>

            </div>

        </div>
    }

</div>
