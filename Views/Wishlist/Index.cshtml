@model IEnumerable<Uniwear.Models.WishlistItem>

<h1 class="fw-bold">FAVOURITES</h1>

@if (!Model.Any())
{
    <p><strong>0 ITEMS</strong></p>

    <p>Tap the heart icon on items to save them here.</p>

    <a asp-controller="Product"
       asp-action="Index"
       class="btn btn-outline-dark">
        EXPLORE UNIWEAR
    </a>
}
else
{
    <div class="row mt-4">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-3">

                <!-- CLICKABLE CARD -->
                <div class="card h-100"
                     onclick="location.href='@Url.Action("Details", "Product", new { id = item.ProductId })'"
                     style="cursor:pointer;">

                    <img src="@item.Product.ImageUrl"
                         class="card-img-top"
                         style="height:250px; object-fit:cover;" />

                    <div class="card-body">

                        <h6>@item.Product.Name</h6>

                        <p>₹ @item.Product.Price</p>
                        
                        <form asp-action="Remove"
                              asp-controller="Wishlist"
                              asp-route-id="@item.Id"
                              method="post"
                              class="d-inline"
                              onsubmit="event.stopPropagation();">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                        </form>
                    </div>

                </div>

            </div>
        }

    </div>
}