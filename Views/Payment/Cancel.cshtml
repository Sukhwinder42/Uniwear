<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-lg border-0 text-center p-5" style="max-width: 420px; border-radius: 15px;">

        <div class="mb-4">
            <div class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                <i class="bi bi-x-lg fs-1"></i>
            </div>
        </div>

        <h3 class="fw-bold mb-2">Payment Cancelled</h3>
        <p class="text-muted mb-4">
            Your payment was not completed. You can try again anytime.
        </p>

        <div class="d-grid gap-2">
            <a asp-controller="Cart" asp-action="Index" class="btn btn-danger btn-lg">
                Return to Cart
            </a>

            <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-secondary">
                View My Orders
            </a>
        </div>

    </div>
</div>