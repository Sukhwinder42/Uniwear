<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-lg border-0 text-center p-5" style="max-width: 420px; border-radius: 15px;">

        <div class="mb-4">
            <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                <i class="bi bi-check-lg fs-1"></i>
            </div>
        </div>

        <h3 class="fw-bold mb-2">Payment Successful 🎉</h3>
        <p class="text-muted mb-4">
            Your order has been placed successfully.
        </p>

        <div class="d-grid gap-2">
            <a asp-controller="Order" asp-action="MyOrders" class="btn btn-success btn-lg">
                View My Orders
            </a>

            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">
                Continue Shopping
            </a>
        </div>

    </div>
</div>