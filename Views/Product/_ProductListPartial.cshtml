@model IEnumerable<Uniwear.ViewModels.ProductViewModel>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-3">

            <div class="card h-100 position-relative product-card"
                 onclick="location.href='@Url.Action("Details", "Product", new { id = item.Id })'"
                 style="cursor:pointer;">

                <a asp-controller="Wishlist"
                   asp-action="Toggle"
                   asp-route-productId="@item.Id"
                   class="wishlist-icon position-absolute"
                   style="top:10px; right:10px;"
                   onclick="event.stopPropagation();">

                    @{
                        var wishlist = ViewBag.Wishlist as List<int>;
                        bool isWishlisted = wishlist != null && wishlist.Contains(item.Id);
                    }

                    <i class="@(isWishlisted ? "fa-solid fa-heart text-danger" : "fa-regular fa-heart")"></i>

                </a>

                <!-- DELETE ICON (ADMIN ONLY) -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Delete"
                       asp-controller="Product"
                       asp-route-id="@item.Id"
                       class="delete-icon position-absolute text-danger"
                       style="top:10px; left:10px; z-index: 10;"
                       onclick="event.stopPropagation();">
                        <i class="bi bi-trash fs-4"></i>
                    </a>
                }

                <!-- PRODUCT IMAGE -->
                <img src="@item.ImageUrl"
                     class="card-img-top"
                     style="height:280px; object-fit:cover;" />

                <div class="card-body">
                    <h6 class="text-uppercase fw-semibold">@item.Name</h6>
                    <p class="fw-bold">₹ @item.Price</p>
                </div>

            </div>

        </div>
    }
</div>