@model List<Uniwear.Models.Product>

<div class="container mt-4">

    <!--  Back Button -->
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark mb-3">
        ← Back to Products
    </a>

    <h2 class="mb-1"> Your Outfit Recommendation</h2>
    <h5 class="text-muted mb-3">Based on: @ViewBag.SelectedProduct.Name</h5>

    @if (ViewBag.AIUsed == true)
    {
        <p class="text-success"><b> AI Generated Outfit</b></p>
    }
    else
    {
        <p class="text-warning"><b> Smart Rule-Based Outfit</b></p>
    }

    <!--  Add Selected to Cart Button -->
    <form asp-controller="Cart" asp-action="AddMultiple" method="post">

        <div class="row mt-4">

            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100 product-card">

                        <!--  Clickable Image -->
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">
                            <img src="@item.ImageUrl" class="card-img-top" height="250" />
                        </a>

                        <div class="card-body d-flex flex-column">

                            <!-- Checkbox -->
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="selectedProductIds"
                                       value="@item.Id" />
                                <label class="form-check-label">
                                    Select
                                </label>
                            </div>

                            <h5>@item.Name</h5>
                            <p class="mb-1">₹@item.Price</p>

                            <p class="text-muted mb-2">
                                <b>@item.Type</b> | @item.Color
                            </p>

                            <!--  View Button -->
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-dark btn-sm mt-auto">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }

        </div>

        <!--  Add to Cart -->
        <div class="text-center mt-3">
            <button type="submit" class="btn btn-dark px-4">
                🛒 Add Selected to Cart
            </button>
        </div>

    </form>
</div>

<!--  Styling -->
<style>
    .product-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 12px;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        }

    .card-img-top {
        object-fit: cover;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }
</style>