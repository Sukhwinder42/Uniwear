@model Uniwear.ViewModels.ProductViewModel

<h2>Add Item</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Description</label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Price</label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="imageUpload">Upload Image</label>
        <input type="file" class="form-control" id="imageUpload" asp-for="ImageFile" />
    </div>

    <div class="form-group">
        <label>Gender Group</label>
        <select asp-for="GenderGroup" class="form-control" required>
            <option value="">Select</option>
            <option value="Men">Men</option>
            <option value="Ladies">Ladies</option>
            <option value="Kids">Kids</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Category</label>
        @foreach (var category in Model.Categories)
        {
            <div class="form-check">
                <input class="form-check-input" type="radio" asp-for="CategoryId" value="@category.Id" />
                <label class="form-check-label">@category.Name</label>
            </div>
        }
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Stock</label>
        <input asp-for="StockQuantity" type="number" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" asp-controller="Product" class="btn btn-outline-dark">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}